#include <windows.h>
#include "resource.h"

IDI_TRAYICON ICON "app.ico"

VS_VERSION_INFO VERSIONINFO
FILEVERSION     1,0,0,0
PRODUCTVERSION  1,0,0,0
FILEFLAGSMASK   VS_FFI_FILEFLAGSMASK
FILEFLAGS       0
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_APP
FILESUBTYPE     VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "OrphanWatch"
            VALUE "FileDescription",  "Process Orphan Monitor"
            VALUE "FileVersion",      "1.0.0.0"
            VALUE "InternalName",     "OrphanWatch"
            VALUE "OriginalFilename", "OrphanWatch.exe"
            VALUE "ProductName",      "OrphanWatch"
            VALUE "ProductVersion",   "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END

// UAC Manifest — require administrator elevation
1 RT_MANIFEST "app.manifest"
